# ─────────────────────────────────────────────────────────────────────
# moSend — Variables para Dokploy (producción)
# Copia a "Environment Variables" de tu aplicación en Dokploy.
# Reemplaza TODOS los valores marcados CHANGE-ME.
# ─────────────────────────────────────────────────────────────────────

# ——— Postgres (si usas el compose, aplica al contenedor postgres) ———
POSTGRES_USER=usesend
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=usesend

# ——— App moSend ———
PORT=3000
NEXTAUTH_URL=https://app.tu-dominio.com
NEXTAUTH_SECRET=CHANGE-ME-generate-with-openssl-rand-base64-32
DATABASE_URL=postgresql://usesend:CHANGE-ME-strong-password@postgres:5432/usesend
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=mosend

# ——— Admin (bootstrap) ———
# Este email será admin automáticamente al entrar. Después puedes promover
# más usuarios desde /admin/teams o directo en DB.
ADMIN_EMAIL=tu-correo@dominio.com

# ——— Secreto para cifrar credenciales de pasarelas (AES-256-GCM) ———
# REQUERIDO. Mínimo 32 caracteres. Genera con:
#   openssl rand -base64 48
ADMIN_CREDS_ENCRYPTION_KEY=CHANGE-ME-at-least-32-random-chars-keep-secret

# ——— AWS SES (envío de correo) ———
AWS_ACCESS_KEY=CHANGE-ME
AWS_SECRET_KEY=CHANGE-ME
AWS_DEFAULT_REGION=us-east-1

# ——— Auth providers (al menos uno) ———
GITHUB_ID=CHANGE-ME
GITHUB_SECRET=CHANGE-ME
# O Google:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ——— Modo cloud (gating de features, límites, waitlist) ———
# true = plataforma pública estilo SaaS (los nuevos users entran a waitlist
#        salvo que tengan invite o seas ADMIN_EMAIL). Recomendado para vender.
# false = self-hosted privado, todos los users son beta.
NEXT_PUBLIC_IS_CLOUD=true

# ——— Rate limit (por Team, sobrescribible desde /admin/teams) ———
API_RATE_LIMIT=1

# ——— SMTP (metadata mostrada a usuarios, no afecta el envío) ———
SMTP_HOST=smtp.tu-dominio.com
SMTP_USER=mosend

# ——— Stripe (opcional; si lo configuras desde /admin/gateways, puedes dejarlos vacíos) ———
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ——— dLocal Go (opcional; se configura desde /admin/gateways directamente) ———
# No hay env vars; las credenciales las guardas cifradas vía el panel admin.
